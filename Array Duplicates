class Solution:
    def findDuplicates(self, arr):
        n = len(arr)
        freq = [0] * (n + 1)
        result = []
        
        for num in arr:
            freq[num] += 1
        
        for i in range(1, n + 1):
            if freq[i] == 2:
                result.append(i)
        
        return result
