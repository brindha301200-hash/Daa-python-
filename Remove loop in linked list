class Solution:
    def removeLoop(self, head):
        slow = head
        fast = head

        # Step 1: Detect loop
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next

            if slow == fast:
                break
        else:
            return True   # No loop

        # Step 2: Find start of loop
        slow = head
        if slow == fast:
            while fast.next != slow:
                fast = fast.next
        else:
            while slow.next != fast.next:
                slow = slow.next
                fast = fast.next

        # Step 3: Remove loop
        fast.next = None
        return True
